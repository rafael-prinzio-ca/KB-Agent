BIGQUERY_PROJECT_ID=SEU_PROJETO_AQUI

# Looker (opcional — necessário para /create-kb com fonte Looker)
LOOKERSDK_BASE_URL=https://your-instance.cloud.looker.com:19999
LOOKERSDK_CLIENT_ID=
LOOKERSDK_CLIENT_SECRET=

# Metabase (opcional — necessário para /create-kb com fonte Metabase)
METABASE_URL=https://your-metabase-instance.com
METABASE_API_KEY=

# GitHub — repos de código sincronizados em repos/ para uso dos agentes de KB.
# Pré-requisito: `gh auth login --hostname github.com` (uma vez), com SSO da org ativado.
# Formato: lista separada por espaço, sem o prefixo da org.
# Vazio = nenhum repo sincronizado; agentes seguem sem acesso a código.
KB_GITHUB_ORG=ContaAzul
KB_GITHUB_REPOS="looker gcp-dataform-contaazul"
