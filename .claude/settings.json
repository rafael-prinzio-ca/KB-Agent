{
  "permissions": {
    "allow": [
      "Bash(./sync-repos.sh)",
      "Bash(./sync-repos.sh:*)",
      "Bash(gh auth status)",
      "Bash(gh auth status:*)",
      "Bash(gh repo clone:*)",
